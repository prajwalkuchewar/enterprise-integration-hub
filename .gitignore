# Root ignore rules for a .NET + Angular monorepo

# OS files
.DS_Store
Thumbs.db

# IDE and editor files
.vs/
**/.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# .NET build artifacts
**/[Bb]in/
**/[Oo]bj/
**/[Dd]ebug/
**/[Rr]elease/
**/[Rr]eleases/
**/artifacts/
**/TestResults/
**/coverage/
*.cache
*.log
*.binlog
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
ScaffoldingReadMe.txt

# Angular / Node.js
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/coverage/
frontend/.turbo/
frontend/.cache/
frontend/.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.*
!.env.example
**.sql
# Temporary files
*.tmp
*.temp
*~
~$*